# Copy to .env.local (gitignored) and fill with real values.
# After setup, also set these in Cloudflare Pages → Settings → Environment variables.

# Apps Script Web App deployment URL (ends in /exec)
PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec

# Shared secret — also set as Script Property ORDER_TOKEN in Apps Script.
# 32+ random chars. Public by design (ends up in bundle); raises the bar for bots.
PUBLIC_ORDER_TOKEN=replace-with-random-32-char-string
