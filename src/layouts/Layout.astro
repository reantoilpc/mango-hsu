---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "芒果許",
  description = "自家栽種、自家加工的金煌與愛文芒果乾。產季限量供應。",
} = Astro.props;

// Admin context: logged-in admin pages get admin nav (訂單/商品/變更紀錄/變更密碼);
// /admin/login stays on customer nav since no session yet.
const pathname = Astro.url.pathname;
const session = (Astro.locals as { session?: { email: string; role: string } }).session;
const isAdminShell = pathname.startsWith("/admin") && !!session;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="bg-mango-50 text-mango-900 min-h-screen flex flex-col">
    <header class="border-b border-mango-200 bg-white/60 backdrop-blur">
      <div class="max-w-4xl mx-auto px-5 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-lg">
          <span class="text-2xl">🥭</span>
          <span>芒果許</span>
        </a>
        {isAdminShell ? (
          <nav class="flex gap-1 text-sm">
            <a href="/admin/orders" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">訂單</a>
            <a href="/admin/products" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">商品</a>
            <a href="/admin/audit" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">變更紀錄</a>
            <a href="/admin/change-password" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">變更密碼</a>
          </nav>
        ) : (
          <nav class="flex gap-1 text-sm">
            <a href="/products" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">產品</a>
            <a href="/order" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">下訂</a>
            <a href="/status" class="px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">查詢</a>
          </nav>
        )}
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-mango-200 bg-white/60 mt-12">
      <div class="max-w-4xl mx-auto px-5 py-6 text-xs text-mango-700 space-y-1">
        <p>芒果許 · 自產自消芒果 · 產季限量供應</p>
        <p>聯絡：<a href="mailto:rhsu1037@gmail.com" class="underline">rhsu1037@gmail.com</a></p>
      </div>
    </footer>
  </body>
</html>
