---
import "../styles/global.css";
import { navItemsForRole, activeNavKey, type AdminRole } from "../lib/admin-nav";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "芒果許",
  description = "自家栽種、自家加工的金煌與愛文芒果乾。產季限量供應。",
} = Astro.props;

// Admin context: logged-in admin pages get admin nav (訂單/商品/變更紀錄/變更密碼);
// /admin/login stays on customer nav since no session yet.
const pathname = Astro.url.pathname;
const session = (Astro.locals as { session?: { email: string; role: string } }).session;
const isAdminShell = pathname.startsWith("/admin") && !!session;
const adminNavItems = isAdminShell
  ? navItemsForRole((session!.role as AdminRole) === "admin" ? "admin" : "operator")
  : [];
const adminActiveKey = isAdminShell ? activeNavKey(pathname) : null;

// Inline SVG favicon (mango motif) so the browser stops fetching a missing
// /favicon.ico (which 404s on every page, polluting the console). The data URI
// is encodeURIComponent'd so the SVG never hits HTML-attribute parsing.
const faviconHref =
  "data:image/svg+xml," +
  encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><circle cx="12" cy="12" r="12" fill="#fef3c7"/><path fill="#f59e0b" d="M18.9 6.4C17.2 4 14 3 11 4.4 7.7 5.9 5.4 8.9 5 12.3c-.3 2.5.7 5 2.8 6.5 2 1.4 4.7 1.5 6.9.3 3.1-1.7 5.3-5 5.6-8.5.1-1.5-.2-3-1.4-4.2z"/></svg>',
  );
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="icon" href={faviconHref} />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="bg-mango-50 text-mango-900 min-h-screen flex flex-col">
    <header class="border-b border-mango-200 bg-white/60 backdrop-blur">
      <div class="max-w-4xl mx-auto px-5 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-lg">
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 text-mango-500" aria-hidden="true">
            <path d="M18.9 6.4C17.2 4 14 3 11 4.4 7.7 5.9 5.4 8.9 5 12.3c-.3 2.5.7 5 2.8 6.5 2 1.4 4.7 1.5 6.9.3 3.1-1.7 5.3-5 5.6-8.5.1-1.5-.2-3-1.4-4.2z"/>
          </svg>
          <span>芒果許</span>
        </a>
        {isAdminShell ? (
          <>
            {/* Desktop: inline nav with active marker. Hidden on mobile. */}
            <nav aria-label="後台導航" class="hidden sm:flex flex-wrap items-center gap-1 text-sm justify-end">
              {adminNavItems.map((item) => (
                <a
                  href={item.href}
                  aria-current={adminActiveKey === item.key ? "page" : undefined}
                  class:list={[
                    "inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700",
                    adminActiveKey === item.key
                      ? "bg-mango-100 text-mango-700 font-semibold"
                      : "",
                  ]}
                >
                  {item.label}
                </a>
              ))}
              {/* FIX #5: logout (a POST, not a nav GET link). */}
              <form method="POST" action="/api/admin/auth/logout" class="contents">
                <button
                  type="submit"
                  class="inline-flex items-center min-h-[44px] px-3 py-2 rounded text-red-700 hover:bg-red-50"
                >
                  登出
                </button>
              </form>
            </nav>
            {/* Mobile: hamburger toggles a drawer. Hidden on desktop. */}
            <button
              type="button"
              data-admin-drawer-toggle
              aria-label="開啟選單"
              aria-expanded="false"
              aria-controls="admin-drawer"
              class="sm:hidden inline-flex items-center justify-center min-h-[44px] min-w-[44px] rounded hover:bg-mango-100 hover:text-mango-700"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true">
                <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </>
        ) : (
          <nav class="flex gap-1 text-sm">
            <a href="/products" class="inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">產品</a>
            <a href="/order" class="inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">下訂</a>
            <a href="/status" class="inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">查詢</a>
          </nav>
        )}
      </div>
    </header>

    {isAdminShell && (
      <div
        id="admin-drawer"
        data-admin-drawer
        hidden
        class="sm:hidden fixed inset-0 z-40"
      >
        <div data-admin-drawer-backdrop class="absolute inset-0 bg-black/40"></div>
        <nav
          aria-label="後台選單"
          class="absolute right-0 top-0 h-full w-64 max-w-[80vw] bg-white shadow-xl p-4 flex flex-col gap-1 overflow-y-auto"
        >
          <div class="mb-2 flex items-center justify-between">
            <span class="font-bold text-mango-700">選單</span>
            <button
              type="button"
              data-admin-drawer-close
              aria-label="關閉選單"
              class="inline-flex items-center justify-center min-h-[44px] min-w-[44px] rounded hover:bg-mango-100"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-6 w-6" aria-hidden="true">
                <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
              </svg>
            </button>
          </div>
          {adminNavItems.map((item) => (
            <a
              href={item.href}
              aria-current={adminActiveKey === item.key ? "page" : undefined}
              class:list={[
                "inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700",
                adminActiveKey === item.key ? "bg-mango-100 text-mango-700 font-semibold" : "",
              ]}
            >
              {item.label}
            </a>
          ))}
          {/* FIX #5: logout (a POST, not a nav GET link). */}
          <form method="POST" action="/api/admin/auth/logout" class="mt-1">
            <button
              type="submit"
              class="w-full text-left inline-flex items-center min-h-[44px] px-3 py-2 rounded text-red-700 hover:bg-red-50"
            >
              登出
            </button>
          </form>
        </nav>
      </div>

      <script>
        const toggle = document.querySelector<HTMLButtonElement>("[data-admin-drawer-toggle]");
        const drawer = document.querySelector<HTMLElement>("[data-admin-drawer]");
        const backdrop = document.querySelector<HTMLElement>("[data-admin-drawer-backdrop]");
        const closeBtn = document.querySelector<HTMLButtonElement>("[data-admin-drawer-close]");

        function openDrawer(): void {
          if (!drawer || !toggle) return;
          drawer.hidden = false;
          toggle.setAttribute("aria-expanded", "true");
          document.body.style.overflow = "hidden";
        }
        function closeDrawer(): void {
          if (!drawer || !toggle) return;
          drawer.hidden = true;
          toggle.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
        }

        toggle?.addEventListener("click", openDrawer);
        closeBtn?.addEventListener("click", closeDrawer);
        backdrop?.addEventListener("click", closeDrawer);
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && drawer && !drawer.hidden) closeDrawer();
        });
      </script>
    )}

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-mango-200 bg-white/60 mt-12">
      <div class="max-w-4xl mx-auto px-5 py-6 text-xs text-mango-700 space-y-1">
        <p>芒果許 · 自產自消芒果 · 產季限量供應</p>
        <p>聯絡：<a href="mailto:rhsu1037@gmail.com" class="underline">rhsu1037@gmail.com</a></p>
      </div>
    </footer>
  </body>
</html>
