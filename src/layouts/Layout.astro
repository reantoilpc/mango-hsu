---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "芒果許",
  description = "自家栽種、自家加工的金煌與愛文芒果乾。產季限量供應。",
} = Astro.props;

// Admin context: logged-in admin pages get admin nav (訂單/商品/變更紀錄/變更密碼);
// /admin/login stays on customer nav since no session yet.
const pathname = Astro.url.pathname;
const session = (Astro.locals as { session?: { email: string; role: string } }).session;
const isAdminShell = pathname.startsWith("/admin") && !!session;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="bg-mango-50 text-mango-900 min-h-screen flex flex-col">
    <header class="border-b border-mango-200 bg-white/60 backdrop-blur">
      <div class="max-w-4xl mx-auto px-5 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-lg">
          <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 text-mango-500" aria-hidden="true">
            <path d="M18.9 6.4C17.2 4 14 3 11 4.4 7.7 5.9 5.4 8.9 5 12.3c-.3 2.5.7 5 2.8 6.5 2 1.4 4.7 1.5 6.9.3 3.1-1.7 5.3-5 5.6-8.5.1-1.5-.2-3-1.4-4.2z"/>
          </svg>
          <span>芒果許</span>
        </a>
        {isAdminShell ? (
          <nav class="flex flex-wrap items-center gap-0.5 sm:gap-1 text-sm justify-end">
            <a href="/admin/orders" class="inline-flex items-center min-h-[44px] px-2 sm:px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">訂單</a>
            <a href="/admin/products" class="inline-flex items-center min-h-[44px] px-2 sm:px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">商品</a>
            <a href="/admin/product-groups" class="inline-flex items-center min-h-[44px] px-2 sm:px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">
              <span class="sm:hidden">庫存</span>
              <span class="hidden sm:inline">庫存池</span>
            </a>
            <a href="/admin/audit" class="inline-flex items-center min-h-[44px] px-2 sm:px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">
              <span class="sm:hidden">紀錄</span>
              <span class="hidden sm:inline">變更紀錄</span>
            </a>
            <a href="/admin/change-password" class="inline-flex items-center min-h-[44px] px-2 sm:px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">
              <span class="sm:hidden">密碼</span>
              <span class="hidden sm:inline">變更密碼</span>
            </a>
          </nav>
        ) : (
          <nav class="flex gap-1 text-sm">
            <a href="/products" class="inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">產品</a>
            <a href="/order" class="inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">下訂</a>
            <a href="/status" class="inline-flex items-center min-h-[44px] px-3 py-2 rounded hover:bg-mango-100 hover:text-mango-700">查詢</a>
          </nav>
        )}
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-mango-200 bg-white/60 mt-12">
      <div class="max-w-4xl mx-auto px-5 py-6 text-xs text-mango-700 space-y-1">
        <p>芒果許 · 自產自消芒果 · 產季限量供應</p>
        <p>聯絡：<a href="mailto:rhsu1037@gmail.com" class="underline">rhsu1037@gmail.com</a></p>
      </div>
    </footer>
  </body>
</html>
