---
import Layout from "../../layouts/Layout.astro";
import { makeDb } from "../../db/client";
import { admin_users } from "../../db/schema";
import { eq } from "drizzle-orm";
import { env } from "../../lib/env";



const session = Astro.locals.session;
if (!session) return Astro.redirect("/admin/login");

const db = makeDb(env);
const userRows = await db
  .select({ must_change_password: admin_users.must_change_password })
  .from(admin_users)
  .where(eq(admin_users.email, session.email))
  .limit(1);
const mustChange = userRows[0]?.must_change_password ?? false;
---

<Layout title="變更密碼">
  <main class="mx-auto max-w-sm px-4 py-12">
    <h1 class="mb-2 text-2xl font-bold">變更密碼</h1>
    {mustChange ? (
      <p class="mb-6 rounded bg-amber-50 px-3 py-2 text-sm text-amber-800">
        系統提供的初始密碼不安全，請先設定自己的密碼後再使用後台。
      </p>
    ) : (
      <p class="mb-6 text-sm text-gray-600">建議定期更換。新密碼至少 8 個字。</p>
    )}

    <div id="msg" class="mb-4 hidden rounded px-3 py-2 text-sm"></div>

    <form id="form" class="space-y-4">
      <div>
        <label for="current" class="block text-sm font-medium mb-1">目前密碼</label>
        <input
          id="current"
          name="current_password"
          type="password"
          required
          autocomplete="current-password"
          class="w-full rounded border border-gray-300 px-3 py-2 text-base"
        />
      </div>
      <div>
        <label for="new" class="block text-sm font-medium mb-1">新密碼（至少 8 字元）</label>
        <input
          id="new"
          name="new_password"
          type="password"
          required
          minlength="8"
          autocomplete="new-password"
          class="w-full rounded border border-gray-300 px-3 py-2 text-base"
        />
      </div>
      <div>
        <label for="confirm" class="block text-sm font-medium mb-1">再輸入一次新密碼</label>
        <input
          id="confirm"
          name="confirm_password"
          type="password"
          required
          minlength="8"
          autocomplete="new-password"
          class="w-full rounded border border-gray-300 px-3 py-2 text-base"
        />
      </div>
      <button
        type="submit"
        class="w-full rounded bg-orange-600 px-4 py-3 text-base font-medium text-white hover:bg-orange-700"
      >
        變更密碼
      </button>
    </form>

    {!mustChange && (
      <p class="mt-6 text-center text-sm">
        <a href="/admin" class="text-gray-600 underline">返回後台</a>
      </p>
    )}
  </main>

  <script>
    const form = document.getElementById("form") as HTMLFormElement;
    const msg = document.getElementById("msg") as HTMLDivElement;

    function showMsg(text: string, kind: "ok" | "err") {
      msg.textContent = text;
      msg.className =
        "mb-4 rounded px-3 py-2 text-sm " +
        (kind === "ok"
          ? "bg-emerald-50 text-emerald-700"
          : "bg-red-50 text-red-700");
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const cur = String(fd.get("current_password") ?? "");
      const nw = String(fd.get("new_password") ?? "");
      const cf = String(fd.get("confirm_password") ?? "");
      if (nw !== cf) {
        showMsg("兩次新密碼不一致。", "err");
        return;
      }
      if (nw.length < 8) {
        showMsg("新密碼至少 8 個字。", "err");
        return;
      }
      if (nw === cur) {
        showMsg("新密碼不可與目前密碼相同。", "err");
        return;
      }
      const res = await fetch("/api/admin/auth/change-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ current_password: cur, new_password: nw }),
      });
      if (res.ok) {
        showMsg("變更成功，1 秒後返回後台首頁⋯", "ok");
        setTimeout(() => (location.href = "/admin"), 1000);
      } else {
        showMsg("變更失敗：" + (await res.text()), "err");
      }
    });
  </script>
</Layout>
