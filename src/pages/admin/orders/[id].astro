---
import Layout from "../../../layouts/Layout.astro";
import StatusStepper from "../../../components/admin/StatusStepper.astro";
import StickyBar from "../../../components/admin/StickyBar.astro";
import Modal from "../../../components/admin/Modal.astro";
import { makeDb } from "../../../db/client";
import { orders, order_items, products, product_groups, audit_log, seasons } from "../../../db/schema";
import { eq, desc } from "drizzle-orm";
import { itemsToReadable, formatTaipei, formatTaipeiShort } from "../../../lib/formatters";
import { env } from "../../../lib/env";

const session = Astro.locals.session;
if (!session) return Astro.redirect("/admin/login");

const id = Astro.params.id;
if (!id || !/^M-\d{8}-\d{3}$/.test(id)) {
  return new Response("Invalid order id", { status: 400 });
}

const db = makeDb(env);
const orderRows = await db.select().from(orders).where(eq(orders.order_id, id)).limit(1);
if (orderRows.length === 0) {
  return new Response("Order not found", { status: 404 });
}
const order = orderRows[0]!;

const itemRows = await db
  .select()
  .from(order_items)
  .where(eq(order_items.order_id, id));
// V5.2: stock derived from product_groups.stock_fen / products.package_fen.
// Inner-join to get the pool, then compute per-SKU available count so the
// "add item" dropdown and qty caps see real numbers (was undefined before).
// FIX #17: scope to THIS order's own season. SKU is only unique per
// (season_id, sku), so without the season filter a future season reusing a
// SKU string would let the wrong product render in the Map keyed by sku.
const productJoined = await db
  .select({
    sku: products.sku,
    name: products.name,
    variant: products.variant,
    package_fen: products.package_fen,
    price: products.price,
    available: products.available,
    group_stock_fen: product_groups.stock_fen,
  })
  .from(products)
  .innerJoin(product_groups, eq(products.group_id, product_groups.id))
  .where(eq(products.season_id, order.season_id));
const productRows = productJoined.map((p) => ({
  ...p,
  stock: Math.floor(p.group_stock_fen / p.package_fen),
}));
const productMap = new Map(productRows.map((p) => [p.sku, p]));
const items = itemRows.map((i) => ({ ...i, product: productMap.get(i.sku) }));

const auditRows = await db
  .select()
  .from(audit_log)
  .where(eq(audit_log.order_id, id))
  .orderBy(desc(audit_log.ts))
  .limit(50);

const isAdmin = session.role === "admin";
const cancellable = !order.paid && !order.shipped && order.cancelled_at === null;
// V4: same gate as cancel — only edit items when the order is still pre-payment.
const itemsEditable = cancellable;
// V5: address/notes editable when not cancelled (paid/shipped still allows
// recipient corrections, matching existing /edit endpoint behavior).
const recipientEditable = isAdmin && order.cancelled_at === null;
const skusOnOrder = new Set(items.map((i) => i.sku));
const sellableForNew = productRows
  .filter((p) => p.available && (p.stock > 0 || skusOnOrder.has(p.sku)))
  .map((p) => ({
    sku: p.sku,
    name: p.name,
    variant: p.variant,
    price: p.price,
    stock: p.stock,
    package_fen: p.package_fen,
  }));

const cancelledMeta =
  order.cancelled_at !== null
    ? `${formatTaipei(order.cancelled_at)} · 庫存已歸還`
    : undefined;

// V6 §5.5: this order's season shipping policy for the client-side preview.
const seasonCfgRows = order.season_id
  ? await db
      .select({ shipping_config: seasons.shipping_config })
      .from(seasons)
      .where(eq(seasons.id, order.season_id))
      .limit(1)
  : [];
const orderShipConfig = seasonCfgRows[0]?.shipping_config ?? null;

// 一鍵複製給家人的訂單訊息(齊頭、無標題/合計列)。品項逐行「品名 規格 ×數量」。
const copyOrderMessage = [
  `訂單時間: ${formatTaipeiShort(order.created_at)}`,
  `客人: ${order.name}`,
  `電話: ${order.phone}`,
  `地址: ${order.address}`,
  `品項:`,
  ...items.map((i) =>
    i.product ? `${i.product.name} ${i.product.variant} ×${i.qty}` : `${i.sku} ×${i.qty}`,
  ),
  `備註欄: ${order.expected_memo}`,
].join("\n");
---

<Layout>
  <main class="mx-auto max-w-3xl px-4 py-6 pb-32">
    <header class="mb-6">
      <a href="/admin/orders" class="text-sm text-gray-600 underline">← 訂單列表</a>
      <div class="mt-1 flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-bold">{order.order_id}</h1>
        <button
          type="button"
          id="copy-order-msg-btn"
          data-copy-msg={JSON.stringify(copyOrderMessage)}
          class="inline-flex items-center gap-1 rounded border border-mango-400 bg-white px-3 py-2 min-h-[44px] text-sm font-medium text-mango-700 hover:bg-mango-100 focus-visible:outline-2 focus-visible:outline-mango-500 focus-visible:outline-offset-2"
        >
          📋 複製訂單訊息
        </button>
      </div>
    </header>

    <section class="mb-6">
      <StatusStepper
        paid={order.paid}
        shipped={order.shipped}
        cancelled_at={order.cancelled_at}
        cancelled_meta={cancelledMeta}
      />
    </section>

    <section class="mb-6 rounded border border-gray-200 p-4" data-dirty-track="recipient">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <h2 class="text-lg font-bold">客人資訊</h2>
        {recipientEditable && (
          <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
            可編輯
          </span>
        )}
      </div>
      <dl class="grid grid-cols-[6rem_1fr] gap-y-3 text-sm">
        <dt class="text-gray-500 self-center">姓名</dt>
        <dd>{order.name}</dd>
        <dt class="text-gray-500 self-center">電話</dt>
        <dd>{order.phone}</dd>
        <dt class="text-gray-500 self-center">下單時間</dt>
        <dd>{formatTaipei(order.created_at)}</dd>
        <dt class="text-gray-500 self-center">地址</dt>
        <dd>
          {recipientEditable ? (
            <input
              type="text"
              name="address"
              data-dirty-key="address"
              value={order.address}
              minlength="5"
              maxlength="200"
              class="w-full rounded border border-gray-300 px-3 py-2 min-h-[44px] text-sm focus-visible:outline-2 focus-visible:outline-mango-500 focus-visible:outline-offset-2"
              aria-label="收件地址"
            />
          ) : (
            <span>{order.address}</span>
          )}
        </dd>
        <dt class="text-gray-500 self-center">客戶備註</dt>
        <dd>
          {recipientEditable ? (
            <input
              type="text"
              name="notes"
              data-dirty-key="notes"
              value={order.notes ?? ""}
              maxlength="500"
              placeholder="（無）"
              class="w-full rounded border border-gray-300 px-3 py-2 min-h-[44px] text-sm focus-visible:outline-2 focus-visible:outline-mango-500 focus-visible:outline-offset-2"
              aria-label="客戶備註"
            />
          ) : (
            <span>{order.notes || "（無）"}</span>
          )}
        </dd>
      </dl>
    </section>

    <section class="mb-6 rounded border border-gray-200 p-4">
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <h2 class="text-lg font-bold" id="items-title">品項 ({itemsToReadable(items)})</h2>
        {itemsEditable && isAdmin && (
          <span class="inline-flex items-center rounded-full bg-mango-100 px-2 py-0.5 text-xs font-medium text-mango-700">
            編輯模式
          </span>
        )}
      </div>
      {itemsEditable && isAdmin && (
        <p class="mb-3 -mt-1 text-xs text-gray-500">
          僅未付款訂單可修改品項；改完按下方〈儲存〉送出。
        </p>
      )}

      {itemsEditable && isAdmin ? (
        <div
          id="items-editor"
          data-order-id={order.order_id}
          data-initial-items={JSON.stringify(items.map((i) => ({ sku: i.sku, qty: i.qty })))}
          data-products={JSON.stringify(sellableForNew)}
        >
          <table class="w-full text-sm">
            <thead class="text-left text-xs text-gray-500">
              <tr>
                <th class="pb-1">品項</th>
                <th class="pb-1 text-right">單價</th>
                <th class="pb-1 text-right">數量</th>
                <th class="pb-1"></th>
              </tr>
            </thead>
            <tbody id="items-rows"></tbody>
          </table>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            <select
              id="add-sku-select"
              class="rounded border border-gray-300 px-2 py-2 min-h-[44px] text-sm"
              aria-label="新增品項選單"
            >
              <option value="">+ 新增品項...</option>
            </select>
            <button
              type="button"
              id="add-sku-btn"
              class="inline-flex items-center justify-center rounded border border-mango-400 bg-white px-3 py-2 min-h-[44px] text-sm text-mango-700 hover:bg-mango-100"
            >
              加入
            </button>
          </div>
          <div class="mt-3 grid grid-cols-2 gap-y-1 border-t border-gray-200 pt-3 text-sm">
            <span class="text-gray-600">小計</span>
            <span class="text-right" id="items-subtotal">${order.subtotal}</span>
            <span class="text-gray-600">運費</span>
            <span class="text-right" id="items-shipping">${order.shipping}</span>
            <span class="font-medium">總計</span>
            <span id="items-total" class="text-right font-medium">${order.total}</span>
          </div>
        </div>
      ) : (
        <table class="w-full text-sm">
          <thead class="text-left text-gray-500">
            <tr>
              <th class="pb-2">品項</th>
              <th class="pb-2 text-right">單價</th>
              <th class="pb-2 text-right">數量</th>
              <th class="pb-2 text-right">小計</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {items.map((i) => (
              <tr>
                <td class="py-2">
                  {i.product ? `${i.product.name}${i.product.variant}` : i.sku}
                </td>
                <td class="py-2 text-right">${i.unit_price}</td>
                <td class="py-2 text-right">{i.qty}</td>
                <td class="py-2 text-right">${i.unit_price * i.qty}</td>
              </tr>
            ))}
          </tbody>
          <tfoot class="border-t border-gray-300 font-medium">
            <tr>
              <td colspan="3" class="pt-2 text-right">小計</td>
              <td class="pt-2 text-right">${order.subtotal}</td>
            </tr>
            <tr>
              <td colspan="3" class="text-right">運費</td>
              <td class="text-right">${order.shipping}</td>
            </tr>
            <tr>
              <td colspan="3" class="text-right">總計</td>
              <td class="text-right">${order.total}</td>
            </tr>
          </tfoot>
        </table>
      )}

      <p class="mt-3 text-sm text-gray-500">
        轉帳備註：<code class="font-mono">{order.expected_memo}</code>
      </p>
    </section>

    {order.cancelled_at === null && (
      <section class="mb-6 rounded border border-gray-200 p-4">
        <h2 class="mb-3 text-lg font-bold">下一步操作</h2>
        {/*
          V6 §5.8: 下一步按鈕「永遠可見」。未達前置條件 → disabled + 灰字說明，
          讓店主看見完整流程（未付款也看得到之後要按「標出貨」）。
          可點性只是可發現性提示；真正授權由 server SQL guard 把關（mark-paid /
          mark-shipped 各自檢查 expected_state，disabled 與之雙保險）。
          已出貨 → 兩個按鈕都 disabled，下方顯示出貨摘要。
        */}
        <ol class="space-y-3">
          {/* 步驟 1：標為已付款 */}
          <li>
            <button
              type="button"
              id="mark-paid"
              data-step="paid"
              disabled={order.paid}
              class="w-full inline-flex items-center justify-center rounded bg-emerald-600 px-4 py-3 min-h-[44px] text-base font-medium text-white hover:bg-emerald-700 disabled:bg-emerald-300 disabled:cursor-not-allowed"
            >
              {order.paid ? "✓ 已付款" : "標為已付款"}
            </button>
            {order.paid && (
              <p class="mt-1 text-xs text-gray-500">已於收款後標記，可繼續出貨。</p>
            )}
          </li>

          {/* 步驟 2：標為已出貨（含物流單號）。未付款 → 整組 disabled + 說明 */}
          <li>
            <div class="flex flex-col gap-2 sm:flex-row">
              <input
                type="text"
                id="tracking-input"
                placeholder="物流單號（選填）"
                value={order.tracking_no ?? ""}
                maxlength="100"
                disabled={!order.paid || order.shipped}
                class="flex-1 rounded border border-gray-300 px-3 py-3 min-h-[44px] text-base focus-visible:outline-2 focus-visible:outline-mango-500 focus-visible:outline-offset-2 disabled:bg-gray-100 disabled:text-gray-400"
                aria-label="物流單號"
              />
              <button
                type="button"
                id="mark-shipped"
                data-step="ship"
                disabled={!order.paid || order.shipped}
                class="inline-flex items-center justify-center rounded bg-blue-600 px-4 py-3 min-h-[44px] text-base font-medium text-white hover:bg-blue-700 disabled:bg-blue-300 disabled:cursor-not-allowed"
              >
                {order.shipped ? "✓ 已出貨" : "標為已出貨"}
              </button>
            </div>
            {!order.paid && (
              <p class="mt-1 text-xs text-gray-500">需先標記已付款，才能標出貨。</p>
            )}
            {order.shipped && (
              <p class="mt-1 text-xs text-gray-700">
                出貨時間 {order.shipped_at ? formatTaipei(order.shipped_at) : "—"}
                {order.tracking_no && ` ／ 物流 ${order.tracking_no}`}
              </p>
            )}
          </li>

          {/* 取消：僅未付款（server 真實 guard：付款後不可取消）。不符條件不渲染按鈕，
              改顯示說明，避免給出一個「按了一定失敗」的紅按鈕。 */}
          {isAdmin && (
            <li class="border-t border-gray-100 pt-3">
              {cancellable ? (
                <button
                  type="button"
                  id="cancel-order"
                  class="w-full inline-flex items-center justify-center rounded border border-red-400 px-4 py-3 min-h-[44px] text-base text-red-700 hover:bg-red-50 disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  取消訂單
                </button>
              ) : (
                <p class="text-xs text-gray-400">已付款或已出貨的訂單無法取消。</p>
              )}
            </li>
          )}
        </ol>
      </section>
    )}

    <section class="rounded border border-gray-200 p-4">
      <h2 class="mb-3 text-lg font-bold">變更歷史</h2>
      <ul class="space-y-2 text-xs text-gray-700" id="audit-list">
        {auditRows.map((a) => (
          <li class="border-l-2 border-gray-200 pl-3">
            <div class="font-mono text-gray-500">{formatTaipei(a.ts)}</div>
            <div>
              <span class="font-medium">{a.user_email}</span> ／ {a.action}
              {a.details && (
                <span class="text-gray-500"> ({a.details})</span>
              )}
            </div>
          </li>
        ))}
        {auditRows.length === 0 && (
          <li class="text-sm text-gray-500" data-empty>（尚無紀錄）</li>
        )}
      </ul>
    </section>
  </main>

  {(itemsEditable || recipientEditable) && <StickyBar scopeId="order-edit" />}

  <Modal
    id="cancel-order-modal"
    title="確定要取消這張訂單？"
    destructive
    confirmLabel="確認取消"
  >
    <p>取消後庫存會自動歸還，這個動作無法復原。</p>
  </Modal>

  <script>
    import { showToast, flashToast, consumeFlash } from "../../../lib/toast";
    import { createDirtyTracker, type DirtyState } from "../../../lib/dirty-tracker";
    import { itemsHash } from "../../../lib/items-hash";
    import { formatTaipei } from "../../../lib/formatters";

    interface ItemWorking {
      sku: string;
      qty: number;
    }
    interface ProductInfo {
      sku: string;
      name: string;
      variant: string;
      price: number;
      stock: number;
      package_fen: number;
    }
    interface ExpectedState {
      paid: boolean;
      shipped: boolean;
      cancelled_at: string | null;
      items_hash?: string;
    }

    const main = document.querySelector("main")!;
    const orderId: string = main
      .querySelector("h1")!
      .textContent!.trim();

    // Initial state from server
    const itemsEditor = document.getElementById("items-editor");
    const initialItems: ItemWorking[] = itemsEditor
      ? JSON.parse(itemsEditor.dataset.initialItems!)
      : [];
    const productsList: ProductInfo[] = itemsEditor
      ? JSON.parse(itemsEditor.dataset.products!)
      : [];
    const productMap = new Map(productsList.map((p) => [p.sku, p]));

    // expected_state + shipping config baked from SSR via JSON island.
    type ShipConfig =
      | { type: "flat"; fee_twd: number }
      | { type: "threshold_jin"; free_over_fen: number; fee_twd: number };
    interface OrderStateIsland extends ExpectedState {
      shippingFeeTwd?: number;
      shippingConfigJson?: string | null;
    }
    const stateNode = document.getElementById("v5-order-state");
    const stateIsland: OrderStateIsland = stateNode
      ? JSON.parse(stateNode.textContent || "{}")
      : { paid: false, shipped: false, cancelled_at: null };
    let expectedState: ExpectedState = {
      paid: stateIsland.paid,
      shipped: stateIsland.shipped,
      cancelled_at: stateIsland.cancelled_at,
      // Items fingerprint at page-load. Sent with every /save so the server
      // can detect another tab modifying items between this page-load and
      // submit (the "double-decrement" race). Only send when the item editor
      // is rendered: for paid/shipped orders the editor is absent, initialItems
      // is [], and itemsHash([]) === "" — the server would read that empty
      // string as a provided-but-stale hash and 409 on every address/notes fix.
      items_hash: itemsEditor ? itemsHash(initialItems) : undefined,
    };
    const shippingFeeTwd = stateIsland.shippingFeeTwd ?? 150;
    // V6 §5.5: parse this order's season shipping_config for the preview.
    let shipCfg: ShipConfig = { type: "flat", fee_twd: shippingFeeTwd };
    try {
      if (stateIsland.shippingConfigJson) {
        shipCfg = JSON.parse(stateIsland.shippingConfigJson) as ShipConfig;
      }
    } catch {
      /* keep flat fallback */
    }
    function previewShipping(totalFen: number): number {
      if (totalFen <= 0) return 0;
      if (shipCfg.type === "flat") return shipCfg.fee_twd;
      return totalFen >= shipCfg.free_over_fen ? 0 : shipCfg.fee_twd;
    }

    // ============ Items working state ============
    let working: ItemWorking[] = initialItems.map((i) => ({ ...i }));

    function itemsDirtyCount(): number {
      // Count: per-sku change (add/remove/qty) = 1 each.
      const initialMap = new Map(initialItems.map((i) => [i.sku, i.qty]));
      const workingMap = new Map(working.map((i) => [i.sku, i.qty]));
      let n = 0;
      for (const [sku, q] of workingMap) {
        if (initialMap.get(sku) !== q) n += 1;
      }
      for (const [sku] of initialMap) {
        if (!workingMap.has(sku)) n += 1;
      }
      return n;
    }

    function recomputeTotals(): void {
      // Skip when items are clean: SSR already rendered server-truthful totals.
      // Recomputing here would stomp the DB-correct shipping/total with a preview
      // that mirrors the server formula but rounds differently.
      if (itemsDirtyCount() === 0) return;
      let subtotal = 0;
      let totalFen = 0;
      for (const w of working) {
        const p = productMap.get(w.sku);
        if (p) {
          subtotal += p.price * w.qty;
          totalFen += p.package_fen * w.qty;
        }
      }
      // V6 §5.5: mirrors src/lib/shipping.ts computeShipping(totalFen, config).
      // Server is authoritative; this is just a preview for the dirty state.
      const shipping = previewShipping(totalFen);
      const subEl = document.getElementById("items-subtotal");
      const shipEl = document.getElementById("items-shipping");
      const totEl = document.getElementById("items-total");
      if (subEl) subEl.textContent = "$" + subtotal;
      if (shipEl) shipEl.textContent = "$" + shipping;
      if (totEl) totEl.textContent = "$" + (subtotal + shipping);
    }

    function renderSelect(): void {
      const selectEl = document.getElementById("add-sku-select") as HTMLSelectElement | null;
      if (!selectEl) return;
      const onOrder = new Set(working.map((i) => i.sku));
      selectEl.innerHTML = '<option value="">+ 新增品項...</option>';
      for (const p of productsList) {
        if (onOrder.has(p.sku)) continue;
        const opt = document.createElement("option");
        opt.value = p.sku;
        opt.textContent = `${p.name} ${p.variant} ($${p.price}, 剩 ${p.stock})`;
        selectEl.appendChild(opt);
      }
    }

    function renderItemsRows(): void {
      const rowsEl = document.getElementById("items-rows");
      if (!rowsEl) return;
      rowsEl.innerHTML = "";
      for (const item of working) {
        const p = productMap.get(item.sku);
        const initialQty = initialItems.find((x) => x.sku === item.sku)?.qty ?? 0;
        const max = p
          ? Math.min(99, Math.max(p.stock + initialQty, item.qty))
          : 99;
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td class="py-1">${p ? `${p.name} ${p.variant}` : item.sku}</td>
          <td class="py-1 text-right">$${p ? p.price : "?"}</td>
          <td class="py-1 text-right">
            <input
              type="number"
              min="1"
              max="${max}"
              value="${item.qty}"
              data-sku="${item.sku}"
              class="qty-input w-16 rounded border border-gray-300 px-2 py-1 min-h-[44px] text-right focus-visible:outline-2 focus-visible:outline-mango-500 focus-visible:outline-offset-2"
              aria-label="${p?.name ?? item.sku} 數量"
            />
          </td>
          <td class="py-1 text-right">
            <button
              type="button"
              data-remove-sku="${item.sku}"
              class="inline-flex items-center justify-center rounded border border-red-300 min-h-[44px] min-w-[44px] px-2 text-red-700 hover:bg-red-50"
              aria-label="移除 ${p?.name ?? item.sku}"
              title="移除此品項"
            >
              ✕
            </button>
          </td>
        `;
        rowsEl.appendChild(tr);
      }

      rowsEl.querySelectorAll<HTMLInputElement>(".qty-input").forEach((el) => {
        el.addEventListener("input", (e) => {
          const target = e.target as HTMLInputElement;
          const sku = target.dataset.sku!;
          const qty = Math.max(1, Math.floor(Number(target.value) || 1));
          const it = working.find((x) => x.sku === sku);
          if (it) it.qty = qty;
          recomputeTotals();
          updateStickyBar();
        });
      });
      rowsEl.querySelectorAll<HTMLButtonElement>("[data-remove-sku]").forEach((el) => {
        el.addEventListener("click", (e) => {
          const target = (e.currentTarget || e.target) as HTMLButtonElement;
          const sku = target.dataset.removeSku!;
          working = working.filter((x) => x.sku !== sku);
          renderSelect();
          renderItemsRows();
          recomputeTotals();
          updateStickyBar();
        });
      });
    }

    document.getElementById("add-sku-btn")?.addEventListener("click", () => {
      const selectEl = document.getElementById("add-sku-select") as HTMLSelectElement;
      const sku = selectEl.value;
      if (!sku) return;
      if (working.some((x) => x.sku === sku)) return;
      working.push({ sku, qty: 1 });
      renderSelect();
      renderItemsRows();
      recomputeTotals();
      updateStickyBar();
      selectEl.value = "";
    });

    // ============ Recipient (address/notes) dirty tracker ============
    let recipientTracker: ReturnType<typeof createDirtyTracker> | null = null;
    const recipientSection = document.querySelector<HTMLElement>(
      '[data-dirty-track="recipient"]',
    );
    if (recipientSection) {
      recipientTracker = createDirtyTracker({
        root: recipientSection,
        onChange: () => updateStickyBar(),
      });
    }

    // ============ Sticky bar wire-up ============
    const stickyBar = document.querySelector<HTMLElement>('[data-sticky-bar="order-edit"]');
    const stickyCount = document.querySelector<HTMLElement>('[data-sticky-count="order-edit"]');
    const stickySave = document.querySelector<HTMLButtonElement>(
      '[data-sticky-save="order-edit"]',
    );
    const stickyDiscard = document.querySelector<HTMLButtonElement>(
      '[data-sticky-discard="order-edit"]',
    );
    const stickySaveLabel = document.querySelector<HTMLElement>(
      '[data-sticky-save-label="order-edit"]',
    );

    let saving = false;

    function totalDirty(): number {
      const recipientCount = recipientTracker?.getDirty().count ?? 0;
      return recipientCount + itemsDirtyCount();
    }

    function updateStickyBar(): void {
      if (!stickyBar || !stickyCount) return;
      const n = totalDirty();
      stickyCount.textContent = `儲存 ${n} 處變動`;
      if (n === 0) stickyBar.classList.add("hidden");
      else stickyBar.classList.remove("hidden");
    }

    function lockAll(): void {
      saving = true;
      recipientTracker?.lock();
      document.querySelectorAll<HTMLButtonElement>(
        '#mark-paid, #mark-shipped, #cancel-order, #add-sku-btn',
      ).forEach((b) => (b.disabled = true));
      document
        .querySelectorAll<HTMLInputElement>(".qty-input, [data-remove-sku], #tracking-input, #add-sku-select")
        .forEach((el) => ((el as HTMLInputElement).disabled = true));
      if (stickySave) stickySave.disabled = true;
      if (stickyDiscard) stickyDiscard.disabled = true;
      if (stickySaveLabel) stickySaveLabel.textContent = "儲存中...";
    }

    function unlockAll(): void {
      saving = false;
      recipientTracker?.unlock();
      document.querySelectorAll<HTMLButtonElement>(
        '#mark-paid, #mark-shipped, #cancel-order, #add-sku-btn',
      ).forEach((b) => (b.disabled = false));
      document
        .querySelectorAll<HTMLInputElement>(".qty-input, [data-remove-sku], #tracking-input, #add-sku-select")
        .forEach((el) => ((el as HTMLInputElement).disabled = false));
      if (stickySave) stickySave.disabled = false;
      if (stickyDiscard) stickyDiscard.disabled = false;
      if (stickySaveLabel) stickySaveLabel.textContent = "儲存";
    }

    async function doSave(): Promise<void> {
      if (saving) return;
      const dirtyN = totalDirty();
      if (dirtyN === 0) return;

      const payload: Record<string, unknown> = {
        expected_state: expectedState,
        idempotency_key: crypto.randomUUID(),
      };
      const recipientDirty = recipientTracker?.getDirty();
      if (recipientDirty?.changed.has("address")) {
        payload.address = recipientDirty.changed.get("address")!.after as string;
      }
      if (recipientDirty?.changed.has("notes")) {
        payload.notes = recipientDirty.changed.get("notes")!.after as string;
      }
      if (itemsEditor && itemsDirtyCount() > 0) {
        if (working.length === 0) {
          showToast("至少要保留一個品項", { kind: "error" });
          return;
        }
        payload.items = working;
      }

      lockAll();
      try {
        const res = await fetch(`/api/admin/orders/${orderId}/save`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify(payload),
        });
        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error_code?: string;
          message?: string;
          sold_out_sku?: string;
          current_state?: ExpectedState;
        };
        if (res.status === 409 && data.error_code === "STALE_STATE" && data.current_state) {
          showToast("資料已被其他視窗變更，請重新整理", { kind: "error" });
          // Update expected state so user can retry after reload
          expectedState = data.current_state;
          unlockAll();
          return;
        }
        if (!res.ok || data.ok === false) {
          const code = data.error_code ?? res.status;
          const sku = data.sold_out_sku ? `（${data.sold_out_sku}）` : "";
          showToast(`儲存失敗：${code}${sku}`, { kind: "error" });
          unlockAll();
          return;
        }
        // Local DOM update — no reload, no white flash. Server response has
        // the new authoritative order/items/audit state.
        applyServerState(
          data as unknown as {
            order: Record<string, unknown>;
            items: Array<{ sku: string; qty: number; unit_price: number }>;
            audit_log: Array<{ ts: string; user_email: string; action: string; details: string | null }>;
          },
        );
        showToast("已儲存", { kind: "success" });
        unlockAll();
      } catch {
        showToast("網路錯誤，請稍後再試", { kind: "error" });
        unlockAll();
      }
    }

    async function doDiscard(): Promise<void> {
      if (saving) return;
      if (totalDirty() === 0) return;
      recipientTracker?.discard();
      working = initialItems.map((i) => ({ ...i }));
      renderSelect();
      renderItemsRows();
      recomputeTotals();
      updateStickyBar();
    }

    // Apply server response after a successful save so the page reflects DB
    // state without a full reload. Replaces the old location.reload() — saves
    // the round-trip cost AND lets the success toast stay visible.
    function applyServerState(data: {
      order: Record<string, unknown>;
      items: Array<{ sku: string; qty: number; unit_price: number }>;
      audit_log: Array<{ ts: string; user_email: string; action: string; details: string | null }>;
    }): void {
      const ord = data.order;
      // 1) Address/notes — sync to server-normalized value (may have trimmed
      //    whitespace etc). Use textContent? No — these are <textarea>/<input>.
      const addrEl = document.querySelector<HTMLTextAreaElement | HTMLInputElement>(
        '[data-dirty-key="address"]',
      );
      if (addrEl && typeof ord.address === "string") addrEl.value = ord.address;
      const notesEl = document.querySelector<HTMLTextAreaElement | HTMLInputElement>(
        '[data-dirty-key="notes"]',
      );
      if (notesEl) notesEl.value = typeof ord.notes === "string" ? ord.notes : "";

      // 2) Items — update working[] + initialItems and re-render
      const newItems = data.items.map((i) => ({ sku: i.sku, qty: i.qty }));
      initialItems.length = 0;
      initialItems.push(...newItems);
      working = newItems.map((i) => ({ ...i }));
      if (itemsEditor) {
        renderSelect();
        renderItemsRows();
      }

      // 3) Items title (the "(芒果 ×N)" summary in the H2)
      const titleEl = document.getElementById("items-title");
      if (titleEl) {
        const readable = newItems.length === 0
          ? "(無品項)"
          : newItems
              .map((i) => {
                const p = productMap.get(i.sku);
                const label = p ? `${p.name}${p.variant}` : i.sku;
                return `${label} ×${i.qty}`;
              })
              .join("、");
        titleEl.textContent = `品項 (${readable})`;
      }

      // 4) Totals from server (authoritative)
      const subEl = document.getElementById("items-subtotal");
      const shipEl = document.getElementById("items-shipping");
      const totEl = document.getElementById("items-total");
      if (subEl && typeof ord.subtotal === "number") subEl.textContent = "$" + ord.subtotal;
      if (shipEl && typeof ord.shipping === "number") shipEl.textContent = "$" + ord.shipping;
      if (totEl && typeof ord.total === "number") totEl.textContent = "$" + ord.total;

      // 5) Reset dirty tracker baseline to the new server values
      recipientTracker?.clear();

      // 6) Update expected_state items_hash so the next save can race-detect
      expectedState.items_hash = itemsHash(newItems);

      // 7) Audit list — full replace using the rows server sent
      const auditList = document.getElementById("audit-list");
      if (auditList) {
        auditList.innerHTML = "";
        for (const a of data.audit_log) {
          const li = document.createElement("li");
          li.className = "border-l-2 border-gray-200 pl-3";
          const tsDiv = document.createElement("div");
          tsDiv.className = "font-mono text-gray-500";
          tsDiv.textContent = formatTaipei(a.ts);
          const bodyDiv = document.createElement("div");
          const userSpan = document.createElement("span");
          userSpan.className = "font-medium";
          userSpan.textContent = a.user_email;
          bodyDiv.appendChild(userSpan);
          bodyDiv.appendChild(document.createTextNode(` ／ ${a.action}`));
          if (a.details) {
            const detSpan = document.createElement("span");
            detSpan.className = "text-gray-500";
            detSpan.textContent = ` (${a.details})`;
            bodyDiv.appendChild(detSpan);
          }
          li.appendChild(tsDiv);
          li.appendChild(bodyDiv);
          auditList.appendChild(li);
        }
        if (data.audit_log.length === 0) {
          const empty = document.createElement("li");
          empty.className = "text-sm text-gray-500";
          empty.dataset.empty = "";
          empty.textContent = "（尚無紀錄）";
          auditList.appendChild(empty);
        }
      }

      // 8) Sticky bar should disappear (clean state)
      updateStickyBar();
    }

    stickySave?.addEventListener("click", doSave);
    stickyDiscard?.addEventListener("click", doDiscard);

    document.addEventListener("keydown", (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "s") {
        e.preventDefault();
        if (totalDirty() > 0 && !saving) doSave();
      } else if (e.key === "Escape") {
        if (totalDirty() > 0 && !saving) doDiscard();
      }
    });

    window.addEventListener("beforeunload", (e) => {
      if (totalDirty() > 0) {
        e.preventDefault();
        e.returnValue = "";
      }
    });

    // ============ Status events (independent of sticky bar) ============
    function statusBody(extra: Record<string, unknown> = {}): Record<string, unknown> {
      // Status events send expected_state for early stale detection. Server
      // SQL guards still enforce data correctness — this just lets server
      // return a clear STALE_STATE error before doing any work.
      return {
        expected_state: {
          paid: expectedState.paid,
          shipped: expectedState.shipped,
          cancelled_at: expectedState.cancelled_at,
        },
        ...extra,
      };
    }

    async function statusEvent(
      path: string,
      extra: Record<string, unknown>,
      label: string,
    ): Promise<void> {
      lockAll();
      try {
        const res = await fetch(`/api/admin/orders/${orderId}${path}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify(statusBody(extra)),
        });
        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error_code?: string;
        };
        if (res.status === 409 && data.error_code === "STALE_STATE") {
          showToast("訂單狀態已被其他視窗變更，請重新整理", { kind: "error" });
          unlockAll();
          return;
        }
        if (!res.ok) {
          showToast(`${label}失敗：${res.status}`, { kind: "error" });
          unlockAll();
          return;
        }
        flashToast(`${label}成功`, { kind: "success" });
        location.reload();
      } catch {
        showToast("網路錯誤", { kind: "error" });
        unlockAll();
      }
    }

    document.getElementById("mark-paid")?.addEventListener("click", (e) => {
      // Buttons now always render; a disabled next-step must never POST.
      if ((e.currentTarget as HTMLButtonElement).disabled) return;
      statusEvent("/mark-paid", {}, "標為已付款");
    });
    document.getElementById("mark-shipped")?.addEventListener("click", (e) => {
      if ((e.currentTarget as HTMLButtonElement).disabled) return;
      const trackingInput = document.getElementById("tracking-input") as HTMLInputElement | null;
      const trackingNo = trackingInput?.value.trim() ?? "";
      statusEvent("/mark-shipped", { tracking_no: trackingNo }, "標為已出貨");
    });

    // Cancel modal flow
    const cancelDlg = document.getElementById("cancel-order-modal") as HTMLDialogElement | null;
    document.getElementById("cancel-order")?.addEventListener("click", () => {
      cancelDlg?.showModal();
    });
    cancelDlg?.querySelector("[data-modal-confirm]")?.addEventListener("click", async () => {
      cancelDlg.close();
      lockAll();
      try {
        const res = await fetch(`/api/admin/orders/${orderId}/cancel`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify(statusBody()),
        });
        const data = (await res.json().catch(() => ({}))) as {
          ok?: boolean;
          error_code?: string;
        };
        if (res.status === 409 && data.error_code === "STALE_STATE") {
          showToast("訂單狀態已被其他視窗變更，請重新整理", { kind: "error" });
          unlockAll();
          return;
        }
        if (!res.ok) {
          showToast(`取消失敗：${res.status}`, { kind: "error" });
          unlockAll();
          return;
        }
        showToast("訂單已取消", { kind: "success" });
        setTimeout(() => (location.href = "/admin/orders"), 600);
      } catch {
        showToast("網路錯誤", { kind: "error" });
        unlockAll();
      }
    });

    // ============ 複製訂單訊息（給家人）============
    const copyBtn = document.getElementById("copy-order-msg-btn");
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        const text = JSON.parse(copyBtn.dataset.copyMsg || '""') as string;
        const ok = await copyToClipboard(text);
        showToast(ok ? "已複製訂單訊息" : "複製失敗，請長按手動選取", {
          kind: ok ? "success" : "error",
        });
      });
    }

    async function copyToClipboard(text: string): Promise<boolean> {
      // navigator.clipboard needs a secure context (admin is always HTTPS).
      // execCommand fallback covers older browsers / edge cases.
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        try {
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          const ok = document.execCommand("copy");
          document.body.removeChild(ta);
          return ok;
        } catch {
          return false;
        }
      }
    }

    // ============ Init ============
    if (itemsEditor) {
      renderSelect();
      renderItemsRows();
      recomputeTotals();
    }
    updateStickyBar();
    // Surface any toast queued by the previous page (post-save reload).
    consumeFlash();
  </script>

  <script
    is:inline
    type="application/json"
    id="v5-order-state"
    set:html={JSON.stringify({
      paid: order.paid,
      shipped: order.shipped,
      cancelled_at: order.cancelled_at,
      shippingFeeTwd: parseInt(env.SHIPPING_FEE_TWD, 10) || 150,
      shippingConfigJson: orderShipConfig,
    })}
  />
</Layout>
