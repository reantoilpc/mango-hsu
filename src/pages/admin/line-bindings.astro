---
import Layout from "../../layouts/Layout.astro";
import { makeDb } from "../../db/client";
import { env } from "../../lib/env";
import { queryLineBindings, shapeLineBindings } from "../../lib/line-bindings";
import { formatTaipei } from "../../lib/formatters";

// Admin-only. middleware gates /admin/** by session presence but NOT by role,
// so the role check here is mandatory (same idiom as seasons/index.astro:8-12).
// This page shows customer PII (name + phone), so operators must not reach it
// even by typing the URL.
const session = Astro.locals.session;
if (!session) return Astro.redirect("/admin/login");
if (session.role !== "admin") {
  return new Response("admin only", { status: 403 });
}

const db = makeDb(env);
const summary = shapeLineBindings(await queryLineBindings(db));
---

<Layout title="LINE 綁定">
  <main class="mx-auto max-w-3xl px-4 py-6 pb-12">
    <header class="mb-4 flex items-center justify-between">
      <h1 class="text-2xl font-bold">LINE 綁定</h1>
      <a href="/admin" class="text-sm text-gray-600 underline">← 後台首頁</a>
    </header>

    <p class="mb-4 text-sm text-gray-600">
      已透過 LINE 綁定訂單的客人名單。綁定後，出貨時會自動推播通知給對方。
      「綁定的是誰」以該訂單的姓名／電話辨識（不是 LINE 暱稱）。
    </p>

    <!-- 統計 -->
    <section class="mb-5 grid grid-cols-3 gap-3">
      <div class="rounded border border-gray-200 bg-white p-3 text-center">
        <div class="text-2xl font-bold text-mango-700">{summary.totalPeople}</div>
        <div class="text-xs text-gray-500">已綁定人數（不重複）</div>
      </div>
      <div class="rounded border border-gray-200 bg-white p-3 text-center">
        <div class="text-2xl font-bold">{summary.totalOrders}</div>
        <div class="text-xs text-gray-500">已綁訂單數</div>
      </div>
      <div class="rounded border border-gray-200 bg-white p-3 text-center">
        <div class="text-2xl font-bold">{summary.pushedOrders}</div>
        <div class="text-xs text-gray-500">已推播出貨</div>
      </div>
    </section>

    {summary.hasBindings && (
      <div class="mb-4">
        <input
          id="lb-search"
          type="search"
          inputmode="search"
          aria-label="搜尋姓名或電話"
          placeholder="搜尋姓名或電話…"
          class="w-full rounded border border-gray-300 px-3 py-2 min-h-[44px] text-sm focus-visible:outline-2 focus-visible:outline-mango-500"
        />
        <p id="lb-no-match" class="mt-3 hidden rounded border border-gray-200 bg-gray-50 px-4 py-6 text-center text-sm text-gray-500">
          沒有符合「<span data-q></span>」的綁定客人。
        </p>
      </div>
    )}

    {!summary.hasBindings && (
      <p class="rounded border border-gray-200 bg-gray-50 px-4 py-8 text-center text-sm text-gray-500">
        目前還沒有任何客人綁定 LINE。客人從訂單頁掃 QR 完成 LIFF 綁定後，就會出現在這裡。
      </p>
    )}

    <!-- 名單 -->
    <section id="lb-list" class="space-y-3">
      {summary.people.map((p) => (
        <article
          class="rounded border border-gray-200 bg-white p-4"
          data-person
          data-search={`${p.name} ${p.phone}`.toLowerCase()}
        >
          <div class="flex flex-wrap items-baseline justify-between gap-x-3 gap-y-1">
            <div>
              <span class="font-bold">{p.name}</span>
              <a
                href={`tel:${p.phone}`}
                class="ml-2 font-mono text-sm text-gray-600 underline-offset-2 hover:underline"
              >
                {p.phone}
              </a>
            </div>
            <div class="text-xs text-gray-500">
              {p.orders.length > 1 ? `${p.orders.length} 張訂單 · ` : ""}最近綁定 {formatTaipei(p.latestBoundAt)}
            </div>
          </div>

          <ul class="mt-3 space-y-1.5 border-t border-gray-100 pt-3">
            {p.orders.map((o) => (
              <li class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm">
                <a
                  href={`/admin/orders/${o.orderId}`}
                  class={`font-mono underline-offset-2 hover:underline ${o.cancelled ? "text-gray-400 line-through" : "text-mango-700"}`}
                >
                  {o.orderId}
                </a>
                <span class="text-xs text-gray-400">綁定 {formatTaipei(o.boundAt)}</span>
                {o.cancelled && (
                  <span class="inline-block rounded bg-gray-100 px-1.5 py-0.5 text-xs text-gray-500">已取消</span>
                )}
                {!o.cancelled && o.pushSent && (
                  <span class="inline-block rounded bg-emerald-100 px-1.5 py-0.5 text-xs text-emerald-800">已推播 ✓</span>
                )}
                {!o.cancelled && !o.pushSent && o.shipped && (
                  <span class="inline-block rounded bg-amber-100 px-1.5 py-0.5 text-xs text-amber-800">已出貨·未推播</span>
                )}
                {!o.cancelled && !o.pushSent && !o.shipped && (
                  <span class="inline-block rounded bg-gray-100 px-1.5 py-0.5 text-xs text-gray-500">未出貨</span>
                )}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>

  <script>
    // Client-side filter by name/phone. Small dataset → no server round-trip.
    const input = document.getElementById("lb-search") as HTMLInputElement | null;
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-person]"));
    const noMatch = document.getElementById("lb-no-match");
    const qEcho = noMatch?.querySelector<HTMLElement>("[data-q]") ?? null;

    if (input) {
      input.addEventListener("input", () => {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        for (const card of cards) {
          const hay = card.dataset.search ?? "";
          const show = q === "" || hay.includes(q);
          card.classList.toggle("hidden", !show);
          if (show) visible += 1;
        }
        if (noMatch) {
          const none = visible === 0 && q !== "";
          noMatch.classList.toggle("hidden", !none);
          if (none && qEcho) qEcho.textContent = input.value.trim();
        }
      });
    }
  </script>
</Layout>
