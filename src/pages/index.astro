---
import Layout from "../layouts/Layout.astro";
import { env } from "../lib/env";
import { loadSiteSettings } from "../lib/site-settings";

const settings = await loadSiteSettings(env);
// Three states drive what the hero shows:
//   season closed (!accepting)            → 暫停接單
//   accepting + no sellable stock          → 本季售完
//   accepting + has stock                  → 接單中 (happy path)
// The middle state existed before but was undetected — pill said 接單中 while
// /order rendered 今年全部售完, sending users to a dead end.
const accepting = settings.accepting_dry;
const hasStock = settings.products.some((p) => p.available && p.derived_available_count > 0);
const orderState: "closed" | "soldout" | "open" = !accepting
  ? "closed"
  : hasStock
    ? "open"
    : "soldout";
---

<Layout title="芒果許 — 自產自消芒果">
  <section class="max-w-4xl mx-auto px-5 pt-10 pb-14">
    <div class="flex flex-col gap-3 items-start">
      <span
        class:list={[
          "inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1 rounded-full",
          orderState === "open"
            ? "bg-mango-500 text-white"
            : "bg-mango-100 text-mango-700",
        ]}
      >
        <span
          class:list={[
            "w-1.5 h-1.5 rounded-full",
            orderState === "open" ? "bg-white" : "bg-mango-700",
          ]}
        ></span>
        {orderState === "open"
          ? "本季接單中"
          : orderState === "soldout"
            ? "今年全部售完，下一季見"
            : "目前暫停接單，下一季見"}
      </span>

      <h1 class="text-4xl md:text-5xl font-bold leading-tight mt-2">
        自家芒果<br />
        自家曬乾
      </h1>

      <p class="text-lg text-mango-700 max-w-xl">
        金煌與愛文芒果乾，從自家果園採收、晾曬、包裝。
        不加人工甜味，只用果肉本身的甜。
      </p>

      {
        orderState === "open" && (
          <div class="flex flex-wrap gap-3 pt-4">
            <a
              href="/order"
              class="bg-mango-500 hover:bg-mango-600 text-white font-semibold px-6 py-3 rounded-lg transition"
            >
              我要訂購
            </a>
            <a
              href="/products"
              class="border border-mango-300 hover:border-mango-500 text-mango-700 font-semibold px-6 py-3 rounded-lg transition"
            >
              看產品介紹
            </a>
          </div>
        )
      }

      {
        orderState === "soldout" && (
          <div class="flex flex-wrap gap-3 pt-4">
            <a
              href="/products"
              class="border border-mango-300 hover:border-mango-500 text-mango-700 font-semibold px-6 py-3 rounded-lg transition"
            >
              看產品介紹
            </a>
          </div>
        )
      }

      {
        orderState !== "open" && (
          <p class="text-sm text-mango-700 pt-2">
            想要知道下一季開賣消息，直接私訊我們的 LINE{" "}
            <span class="font-mono">{settings.support_line_id}</span>
          </p>
        )
      }
    </div>
  </section>

  <section class="bg-white/50 border-y border-mango-200">
    <div class="max-w-4xl mx-auto px-5 py-10 grid gap-6 md:grid-cols-3">
      <div>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 text-mango-600" aria-hidden="true">
          <path d="M12 3c-2.8 0-4.5 2.3-4.5 4.5 0 .9.3 1.6.7 2.2-1.7.4-3.2 2-3.2 4 0 2 1.5 3.7 3.5 4h2.5v4h2v-4h2.5c2 -.3 3.5-2 3.5-4 0-2-1.5-3.6-3.2-4 .4-.6.7-1.3.7-2.2C16.5 5.3 14.8 3 12 3z"/>
        </svg>
        <h3 class="font-semibold mt-2">自家果園</h3>
        <p class="text-sm text-mango-700 mt-1">
          從採收到加工都在家裡，沒有代工、沒有大盤商，每一批都看得到。
        </p>
      </div>
      <div>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 text-mango-600" aria-hidden="true">
          <path d="M12 3s-6 7-6 12a6 6 0 0 0 12 0c0-5-6-12-6-12z"/>
        </svg>
        <h3 class="font-semibold mt-2">自然的甜</h3>
        <p class="text-sm text-mango-700 mt-1">
          只用果肉本身的糖分，不額外加糖、不加防腐劑。果香濃、口感紮實。
        </p>
      </div>
      <div>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 text-mango-600" aria-hidden="true">
          <path d="M21 8 12 3 3 8v8l9 5 9-5V8z"/>
          <path d="m3 8 9 5 9-5M12 13v8"/>
        </svg>
        <h3 class="font-semibold mt-2">產季限量</h3>
        <p class="text-sm text-mango-700 mt-1">
          每年產量有限，建議早鳥下單。售完我們會即時更新。
        </p>
      </div>
    </div>
  </section>
</Layout>
